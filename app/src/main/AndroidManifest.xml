<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AguasDelRey">

        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false"
            android:label="@string/title_activity_home"
            android:theme="@style/Theme.AguasDelRey.NoActionBar" />

        <activity
            android:name=".ui.route.RouteActivity"
            android:exported="false"
            android:label="@string/title_activity_route"
            android:theme="@style/Theme.AguasDelRey.NoActionBar" />

        <activity
            android:name=".ui.delivery.DeliveryActivity"
            android:exported="false"
            android:label="@string/title_activity_delivery"
            android:theme="@style/Theme.AguasDelRey.NoActionBar" />

        <activity
            android:name=".ui.sync.SyncActivity"
            android:exported="false"
            android:label="@string/title_activity_sync"
            android:theme="@style/Theme.AguasDelRey.NoActionBar" />

        <activity
            android:name=".ui.map.MapsActivity"
            android:exported="false"
            android:label="@string/title_activity_maps" />
        <activity
            android:name=".ui.route.SelectRutaActivity"
            android:exported="false"
            android:label="Seleccionar Ruta"
            android:theme="@style/Theme.AguasDelRey.NoActionBar" />

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/google_maps_key" />

    </application>

</manifest>