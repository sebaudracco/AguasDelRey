<?xml version="1.0" encoding="utf-8"?>
<!--
    P2 FIX: tv_name_product tenía layout_width="wrap_content" sin restricción
    de ancho máximo. Se cambia a layout_width="0dp" con constraints
    Start=parent y End=format_counter_subtract para que el texto use
    el espacio disponible y baje de renglón si es largo.
    La altura del item sube a wrap_content para acomodar texto de 2 líneas.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/product"
    android:layout_marginRight="8dp"
    android:layout_marginLeft="8dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:minHeight="45dp">

    <ImageView
        android:id="@+id/iv_product"
        android:layout_width="25dp"
        android:layout_height="25dp"
        app:srcCompat="@drawable/ic_check"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_margin="5dp"/>

    <!--
        P2 FIX: layout_width="0dp" + constraintEnd_toStartOf subtract
        permite que el nombre use todo el ancho disponible y haga
        wrap de texto en lugar de cortarse.
    -->
    <TextView
        android:id="@+id/tv_name_product"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/iv_product"
        app:layout_constraintEnd_toStartOf="@+id/format_counter_subtract"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Café La Virginia 500 gr."/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/ic_minus"
        android:id="@+id/format_counter_subtract"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/format_counter_total"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:text="1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/format_counter_total"
        android:textSize="16sp"
        android:textColor="@android:color/black"
        app:layout_constraintEnd_toStartOf="@+id/format_counter_add"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/format_counter_add"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ly_is_delevered"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:srcCompat="@drawable/ic_baseline_add_24"/>

    <LinearLayout
        android:id="@+id/ly_is_delevered"
        android:layout_width="wrap_content"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swt_is_delevered"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/lblEntregado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10dp"
            android:visibility="gone"
            android:text="@string/producto_entregado"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>