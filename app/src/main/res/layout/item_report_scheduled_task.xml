<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:bottomLeftRadius="7dp"
    android:bottomRightRadius="7dp"
    android:topLeftRadius="7dp"
    android:topRightRadius="7dp"
    android:background="@drawable/final_gradient_top_200"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <ImageView
        android:id="@+id/iv_task_client"
        android:layout_width="60dp"
        android:layout_height="60dp"
        app:srcCompat="@drawable/ic_emotions_happy"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"/>


    <TextView
        android:id="@+id/tv_client_value"
        android:layout_width="0dp"
        style="@style/text_caption_s"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="24dp"
        app:layout_constraintLeft_toRightOf="parent"
        app:layout_constraintRight_toLeftOf="@id/iv_task_client"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/iv_task_client"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Sebastián Baudracco"
        android:textColor="@android:color/black"/>



    <TextView
        android:id="@+id/tv_full_name"
        style="@style/text_caption_s"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:textSize="12sp"
        android:text="@string/name_client"
        android:textColor="@color/gray5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_client_value" />

    <TextView
        android:id="@+id/tv_adress_value"
        style="@style/text_caption_s"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="208dp"
        android:textColor="@android:color/black"
        app:layout_constraintEnd_toStartOf="@+id/pb_in_progress"
        app:layout_constraintTop_toBottomOf="@+id/tv_full_name"
        tools:text="AV SiempreVIVA 721" />

    <TextView
        android:id="@+id/tv_stage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Domicilio"
        style="@style/text_caption_s"
        android:textColor="@color/gray5"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_adress_value" />

    <ImageView
        android:visibility="visible"
        android:id="@+id/iv_person"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/ic_person"
        app:layout_constraintTop_toBottomOf="@+id/tv_stage"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        app:tint="@color/gray5" />

    <TextView
        android:id="@+id/tv_person_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="24dp"
        style="@style/text_caption_s"
        android:text="8"
        android:textSize="16sp"
        android:visibility="visible"
        app:layout_constraintStart_toEndOf="@id/iv_person"
        app:layout_constraintTop_toBottomOf="@+id/tv_stage" />

    <ImageView
        android:visibility="gone"
        android:id="@+id/iv_clock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/ic_clock"
        app:layout_constraintTop_toBottomOf="@+id/tv_stage"
        app:layout_constraintStart_toEndOf="@id/tv_person_count"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        app:tint="@color/gray5" />

    <TextView
        style="@style/text_caption_s"
        android:id="@+id/tv_task_start_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="18:45"
        android:textSize="16sp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_stage"
        app:layout_constraintStart_toEndOf="@id/iv_clock"/>

    <TextView
        android:id="@+id/tv_idle_hours"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Algun otro dato de interés??"
        android:textSize="12sp"
        android:textColor="@color/white"
        android:background="@drawable/background_red_rounded"
        android:padding="4dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/iv_person"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="16dp"/>

    <TextView
        android:id="@+id/tv_physical_progress"
        style="@style/text_caption_s"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:padding="8dp"
        android:text="@string/type_of_client"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_idle_hours" />

    <TextView
        android:id="@+id/tv_in_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/deliver_in_progress"
        android:textColor="@color/color_green"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@+id/pb_in_progress"
        app:layout_constraintEnd_toEndOf="@id/pb_in_progress"
        app:layout_constraintHorizontal_bias="0.815"
        app:layout_constraintStart_toStartOf="@id/pb_in_progress" />

    <ProgressBar
        android:id="@+id/pb_in_progress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_marginEnd="12dp"
        android:layout_marginStart="12dp"
        android:indeterminate="true"
        android:indeterminateBehavior="cycle"
        app:layout_constraintTop_toBottomOf="@+id/tv_stage"
        app:layout_constraintEnd_toEndOf="@id/iv_task_client"
        app:layout_constraintStart_toStartOf="@id/iv_task_client" />

    <TextView
        android:id="@+id/tv_complete_task"
        style="@style/text_caption_s"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:padding="8dp"
        android:text="@string/_start_task"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_idle_hours" />

</androidx.constraintlayout.widget.ConstraintLayout>